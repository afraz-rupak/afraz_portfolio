# Copy to .env and fill in to enable email delivery. The server runs fine
# WITHOUT any of these — messages are always stored to SQLite either way.

# --- Server ---
HOST=127.0.0.1
PORT=5173
# Comma-separated allowed origins, or * for any (same-origin needs nothing here)
ALLOWED_ORIGINS=*

# --- Admin: read stored messages at GET /api/messages (X-Admin-Token header) ---
# Leave unset to keep the endpoint disabled.
# ADMIN_TOKEN=change-me-to-a-long-random-string

# --- Email (SMTP). Set these to also have submissions emailed to you. ---
# Gmail example: create an App Password (not your login password).
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   SMTP_USE_TLS=true
# CONTACT_TO=afrazulhaque865@gmail.com
# SMTP_FROM=youraddress@gmail.com
